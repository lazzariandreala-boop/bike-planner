{
  "name": "gravel-route-planner",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "cap:init": "npx cap add android",
    "cap:sync": "nuxt generate && npx cap sync",
    "cap:open": "npx cap open android",
    "cap:run": "nuxt generate && npx cap sync android && npx cap run android",
    "cap:build:debug": "nuxt generate && npx cap sync android && cd android && ./gradlew assembleDebug",
    "cap:build:release": "nuxt generate && npx cap sync android && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/core": "^6.1.2",
    "@capacitor/geolocation": "^6.0.1",
    "@capacitor/haptics": "^6.0.1",
    "@capacitor/status-bar": "^6.0.2",
    "@pinia/nuxt": "^0.5.4",
    "firebase": "^10.14.1",
    "leaflet": "^1.9.4",
    "maplibre-gl": "^4.7.1",
    "nuxt": "^3.13.0",
    "pinia": "^2.2.2",
    "vue": "^3.5.3",
    "vue-router": "^4.4.3",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "@nuxtjs/tailwindcss": "^6.12.1",
    "@types/leaflet": "^1.9.12",
    "typescript": "^5.5.4",
    "unstorage": "^1.17.5"
  }
}
